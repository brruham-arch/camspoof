<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F0F"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📷 CamSpoof"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Xposed Camera Spoof Module"
        android:textSize="13sp"
        android:textColor="#666666"
        android:layout_marginBottom="40dp"/>

    <!-- Status badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/badge_bg"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:layout_marginBottom="40dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷 Real Camera"
            android:textColor="#FFFFFF"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReal"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📷  Kamera Asli"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"
        app:backgroundTint="#1E1E1E"
        app:strokeColor="#4CAF50"
        app:strokeWidth="1dp"
        app:cornerRadius="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPhoto"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🖼️  Pilih Foto"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"
        app:backgroundTint="#1E1E1E"
        app:strokeColor="#FFC107"
        app:strokeWidth="1dp"
        app:cornerRadius="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVideo"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🎬  Pilih Video"
        android:textSize="15sp"
        android:layout_marginBottom="40dp"
        app:backgroundTint="#1E1E1E"
        app:strokeColor="#F44336"
        app:strokeWidth="1dp"
        app:cornerRadius="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aktifkan module ini di VirtualXposed\nlalu launch target app dari sana"
        android:textColor="#444444"
        android:textSize="12sp"
        android:gravity="center"/>

</LinearLayout>
